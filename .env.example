# AI Provider Configuration
# Choose your AI provider: anthropic, openai, or ollama
AI_PROVIDER=anthropic

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama Configuration (for local/offline use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Terminal Capture Settings
TERMINAL_CAPTURE_BUFFER_SIZE=10000
TERMINAL_CAPTURE_INTERVAL=0.5

# Screenshot Settings
SCREENSHOT_INTERVAL=2.0
SCREENSHOT_QUALITY=95
OCR_ENABLED=true
OCR_LANGUAGE=eng

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/lucifer.log

# Automation Settings
AUTO_SUGGEST_COMMANDS=true
AUTO_EXECUTE_SAFE_COMMANDS=false
CONFIRMATION_REQUIRED=true

# Security Settings
DANGEROUS_COMMANDS_FILTER=true
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log

# Report Settings
REPORT_FORMAT=markdown
REPORT_DIR=reports
AUTO_GENERATE_REPORT=true
