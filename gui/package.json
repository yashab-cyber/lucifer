{
  "name": "lucifer-desktop",
  "version": "1.0.0",
  "description": "Lucifer - AI-Powered Cybersecurity Automation Assistant Desktop App",
  "author": "Yashab Alam <yashabalam9@gmail.com / yashabalam707@gmail.com>",
  "license": "MIT",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run start:react\" \"wait-on http://localhost:3000 && npm run start:electron\"",
    "start:react": "BROWSER=none react-scripts start",
    "start:electron": "electron .",
    "build": "react-scripts build",
    "build:electron": "npm run build && electron-builder",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.6.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.21.1",
    "react-scripts": "5.0.1",
    "react-split-pane": "^0.1.92",
    "socket.io-client": "^4.6.1",
    "styled-components": "^6.1.8",
    "web-vitals": "^2.1.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.yashabalam.lucifer",
    "productName": "Lucifer",
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Security",
      "icon": "public/icon.png",
      "desktop": {
        "Name": "Lucifer",
        "Comment": "AI-Powered Cybersecurity Automation Assistant",
        "Categories": "Security;Network;Development;",
        "Terminal": false,
        "Type": "Application"
      }
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
